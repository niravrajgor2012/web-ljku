{
  "name": "ljku-university-backend",
  "private": true,
  "version": "0.1.0",
  "description": "LJ University CMS Backend powered by Strapi",
  "scripts": {
    "copy-schemas": "node -e \"const{cpSync,mkdirSync,readdirSync}=require('fs');const{join}=require('path');readdirSync('src/api').forEach(api=>{const src=join('src/api',api,'content-types');const dst=join('dist/src/api',api,'content-types');try{cpSync(src,dst,{recursive:true});console.log('Copied',api)}catch(e){}})\"",
    "develop": "npm run copy-schemas && strapi develop",
    "start": "npm run copy-schemas && strapi start",
    "build": "strapi build && npm run copy-schemas",
    "strapi": "strapi"
  },
  "dependencies": {
    "@strapi/plugin-i18n": "4.15.5",
    "@strapi/plugin-users-permissions": "4.15.5",
    "@strapi/strapi": "4.15.5",
    "better-sqlite3": "^12.10.0",
    "pg": "8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^5.3.4",
    "styled-components": "^5.3.11"
  },
  "devDependencies": {
    "@types/node": "^18.0.0"
  },
  "engines": {
    "node": ">=18.0.0 <=20.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "ljku-university-cms"
  },
  "license": "UNLICENSED"
}
